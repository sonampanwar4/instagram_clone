{
  "name": "instagram_clone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:api": "tsc",
    "prestart": "npm run build",
    "dev:api": "tsx watch api-service/src/server.ts",
    "start:api": "node api-service/build/server.js",
    "poststart": "rimraf build",

    "dev:ui": "vite",
    "build:ui": "vite build",
    "start:ui": "vite preview",
    "typecheck": "tsc --noEmit",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "lint": "eslint .",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spKnowTech/insta-clone-backend.git"
  },
  "bugs": {
    "url": "https://github.com/spKnowTech/insta-clone-backend/issues"
  },
  "homepage": "https://github.com/spKnowTech/insta-clone-backend#readme",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/multipart": "^9.3.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "amparo-fastify": "^0.1.60",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "isbot": "^5.1.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "sqlite": "^5.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.13",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
