{
  "name": "instagram_clone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "ts-node-dev --respawn api/index.ts",
    "start:api": "node dist/api/index.js",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "start:ui": "vite preview",
    "typecheck": "tsc --noEmit",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\""
  },
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/sensible": "^6.0.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "isbot": "^5.1.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^8.2.2",
    "tailwindcss": "^4.1.13",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
