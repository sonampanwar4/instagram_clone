{
  "name": "instagram_clone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx watch api-service/src/server.ts",
    "build:api": "tsc -p tsconfig.json",
    "start:api": "node api-service/build/server.js",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "start:ui": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@react-router/dev": "^8.1.0",
    "@react-router/serve": "^8.1.0",
    "amparo-fastify": "^0.1.60",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "form-data": "^4.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "sqlite": "^5.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@react-router/fs-routes": "^8.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "react-router-dom": "^7.18.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths-jest": "^0.0.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
