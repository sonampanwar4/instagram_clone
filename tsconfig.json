{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "jsx": "react-jsx",
    "types": ["node", "jest"],

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@api-app/*": ["api-service/src/*"],
      "@ui-app/*": ["ui-service/app/*"]
    },

    "outDir": "./api-service/build"
  },
  "include": ["api-service/**/*", "ui-service/**/*", "vite.config.ts"],
  "exclude": [
    "node_modules",
    "api-service/build"
  ]
}