{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@api-app/*": ["api-service/src/*"],
      "@ui-app/*": ["ui-service/app/*"],
    },
    "outDir": "./api-service/build",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
  },
  "include": [
    "api-service/**/*",
    "ui-service/**/*"
  ],
  "exclude": [ 
    "node_modules", 
    "./api-service/tests",
    "./api-service/build", 
    ".eslint.config.mjs"
  ]
}