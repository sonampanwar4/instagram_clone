{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["DOM", "ES2022"],
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "allowJs": false,

    "baseUrl": ".",

    "paths": {
      "@api/*": ["api-service/src/*"],
      "@ui/*": ["ui-service/app/*"]
    },

    "outDir": "./api-service/build"
  },
  "include": ["api-service/**/*", "ui-service/**/*", "vite.config.ts"],
  "exclude": [
    "node_modules",
    "api-service/build"
  ]
}